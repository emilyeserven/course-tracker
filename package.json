{
  "name": "emstack",
  "description": "",
  "version": "1.1.0",
  "dependencies": {
    "concurrently": "9.2.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@emilyeserven/eslint-config": "1.1.4",
    "@stylistic/eslint-plugin": "5.10.0",
    "@tanstack/eslint-plugin-query": "5.95.2",
    "@tanstack/eslint-plugin-router": "1.161.6",
    "eslint": "9.39.4",
    "eslint-plugin-better-tailwindcss": "4.3.2",
    "eslint-plugin-react-refresh": "0.5.2",
    "fallow": "^2.96.0",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "syncpack": "14.3.0",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.2"
  },
  "packageManager": "pnpm@10.13.1",
  "private": true,
  "scripts": {
    "build": "pnpm -r run clean && pnpm --filter=@emstack/types build && pnpm --filter=@emstack/middleware --filter=@emstack/client -r build",
    "start": "pnpm --filter=@emstack/gateway start",
    "test": "pnpm run -r test",
    "dev": "docker compose up --wait db && pnpm --filter=@emstack/middleware run push:dev && concurrently -n \"models,server,ui\" -c \"yellow,blue,green\" \"pnpm --filter=@emstack/types --stream run dev\" \"pnpm --filter=@emstack/middleware --stream run dev\" \"pnpm --filter=@emstack/client --stream run dev\"",
    "lint": "eslint . --cache --cache-location node_modules/.cache/eslint/ --cache-strategy content",
    "lint:fix": "eslint . --fix --cache --cache-location node_modules/.cache/eslint/ --cache-strategy content",
    "verify:changed": "node scripts/verify-changed.mjs",
    "fallow": "fallow",
    "fallow:sync-skill": "rm -rf .claude/skills/fallow && cp -R node_modules/fallow/skills/fallow .claude/skills/fallow",
    "typecheck": "pnpm --filter=@emstack/types build && pnpm -r --filter=@emstack/middleware --filter=@emstack/client run typecheck",
    "storybook": "pnpm --filter=@emstack/client run storybook",
    "studio": "pnpm --filter=@emstack/middleware run studio",
    "push:dev": "pnpm --filter=@emstack/middleware run push:dev",
    "push:prod": "pnpm --filter=@emstack/middleware run push:prod",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,mjs,cjs,ts,tsx}": "eslint --fix --cache --cache-location node_modules/.cache/eslint/ --cache-strategy content"
  },
  "type": "module",
  "pnpm": {
    "overrides": {
      "picomatch": "2.3.2",
      "esbuild": ">=0.28.1",
      "shell-quote": ">=1.8.4"
    }
  }
}
