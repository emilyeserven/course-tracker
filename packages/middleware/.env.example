# PostgreSQL connection string
DATABASE_URL=postgres://postgres:password@localhost:5432/coursetracker

# Optional fallback for the Readwise Reader integration. Normally the key is set
# in-app via Settings (stored in the DB); this env var is only used when no key
# has been saved there. Get a token at https://readwise.io/access_token
READWISE_API_KEY=

# Optional fallback for the Todoist integration. Normally the key is set in-app
# via Settings (stored in the DB); this env var is only used when no key has
# been saved there. Get a token at https://app.todoist.com/app/settings/integrations/developer
TODOIST_API_KEY=

# Google Calendar OAuth. Create an OAuth 2.0 "Web application" client in the
# Google Cloud Console (with the Google Calendar API enabled) and register the
# redirect URI below as an authorized redirect URI. The redirect URI must match
# the origin the browser hits: in dev that's the Vite dev server. Tip: set the
# OAuth consent screen to "Production" (it can stay unverified for personal use)
# so refresh tokens don't expire after 7 days.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5173/api/google-calendar/callback
