{
  "name": "@emstack/middleware",
  "description": "",
  "version": "1.0.0",
  "dependencies": {
    "@anthropic-ai/sdk": "0.67.0",
    "@emstack/types": "workspace:*",
    "@fastify/cors": "11.1.0",
    "@fastify/env": "5.0.3",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "5.2.5",
    "@neondatabase/serverless": "1.0.2",
    "dotenv": "17.2.3",
    "dotenv-cli": "11.0.0",
    "drizzle-kit": "0.31.10",
    "drizzle-orm": "0.45.2",
    "fastify": "5.8.5",
    "pg": "8.16.3",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@fastify/type-provider-json-schema-to-ts": "5.0.0",
    "@types/node": "24.10.1",
    "@types/pg": "8.15.6",
    "eslint": "9.39.4",
    "globals": "17.4.0",
    "nodemon": "3.1.14",
    "tsc-alias": "1.8.16",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.2"
  },
  "files": [
    "dist/*"
  ],
  "main": "dist/app.js",
  "packageManager": "pnpm@10.13.1",
  "private": true,
  "scripts": {
    "build": "rm -rf dist tsconfig.build.tsbuildinfo && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json --resolve-full-paths",
    "dev": "nodemon --exec tsx src/app.ts",
    "test": "node --test",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "migrate:prod": "node dist/db/migrate.js",
    "migrate:dev": "dotenv -e .env -- tsx src/db/migrate.ts",
    "push:prod": "pnpm run migrate:prod && drizzle-kit push",
    "push:dev": "pnpm run migrate:dev && dotenv -e .env -- drizzle-kit push",
    "push": "pnpm run push:prod && pnpm run push:dev",
    "db:push": "drizzle-kit push",
    "studio": "pnpm drizzle-kit studio"
  },
  "type": "module"
}
