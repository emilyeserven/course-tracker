{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  // Migrated from knip.json
  "entry": [
    // node --test auto-discovers these; nothing imports them
    "packages/middleware/src/tests/**/*.test.{js,ts}",
    // vitest setupFiles in packages/client/vite.config.ts
    "packages/client/setupTests.js"
  ],
  // Type exports used only in their own file must stay exported anyway:
  // TS declaration inference needs them nameable (TanStack route Search
  // interfaces via routeTree.gen.ts, context state types via hooks)
  "ignoreExportsUsedInFile": {
    "type": true,
    "interface": true
  },
  "ignoreDependencies": [
    "syncpack",
    // runtime peer driver of drizzle-orm/node-postgres, never imported directly
    "pg",
    // pulled in via @emilyeserven/eslint-config (carried over from knip config)
    "eslint-plugin-storybook"
  ],
  "health": {
    // CRAP combines complexity with coverage. No coverage is wired into fallow,
    // so CRAP degrades to ~cyclomatic² and flags every untested-but-moderately-
    // complex function — noise, not signal. Disable the CRAP gate until coverage
    // is passed via --coverage; the cyclomatic/cognitive gates below are the
    // real, coverage-independent signal. Restore a ~30 maxCrap once coverage is
    // wired so CRAP can fail genuinely risky (complex + untested) hot paths.
    "maxCrap": 1000000,
    // Conventional thresholds for a rich React UI (fallow defaults are 20/15,
    // which over-flag dense-but-readable conditional rendering). The full audit
    // gates on these, so anything truly egregious still fails CI.
    "maxCyclomatic": 30,
    "maxCognitive": 25
  }
}
